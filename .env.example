APP_NAME=EVERDEN
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# Seguridad (ISO 27001 / tránsito). En producción: APP_URL=https://... y APP_FORCE_HTTPS=true
APP_FORCE_HTTPS=false
TRUSTED_PROXIES=
SECURITY_HEADERS_ENABLED=true
SECURITY_HSTS_MAX_AGE=31536000
SECURITY_HSTS_INCLUDE_SUBDOMAINS=true
SECURITY_HSTS_PRELOAD=false
SECURITY_CSP_IN_NON_PRODUCTION=false

# Privacidad / LFPDPPP (contacto y retención orientativa)
PRIVACY_CONTACT_EMAIL="${MAIL_FROM_ADDRESS}"
PRIVACY_ORGANIZATION_NAME="${APP_NAME}"
PRIVACY_RETENTION_AUDIT_LOGS_DAYS=730

# Seed de estrés (StressDataSeeder). En production exige STRESS_SEED_ENABLED=true
STRESS_SEED_ENABLED=false
# true = ventas vía flujo real (inventario + caja + finanzas). Más lento; ajusta STRESS_SALES_PER_BRANCH
STRESS_USE_REAL_FLOW=false
STRESS_REAL_FLOW_OPENING_AMOUNT=500
STRESS_TENANTS=3
STRESS_BRANCHES_PER_TENANT=4
STRESS_PRODUCTS_PER_TENANT=120
STRESS_SALES_PER_BRANCH=200
STRESS_AUDIT_ROWS_PER_TENANT=800

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Google OAuth (Iniciar sesión / registro con Google). Deja vacío para ocultar el botón.
# En Google Cloud: credenciales OAuth 2.0 > ID de cliente web. URI de redirección = {APP_URL}/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Opcional: por defecto se usa APP_URL + /auth/google/callback
# GOOGLE_REDIRECT_URI="${APP_URL}/auth/google/callback"

# Impresión térmica / agente local (scripts/print-agent). Opcional.
# En tienda: QUEUE_CONNECTION=database + php artisan queue:work + agente HTTP (ver scripts/start-store-stack.cmd).
PRINT_AFTER_PAY=false
PRINT_NOTIFY_AGENT=false
PRINT_AGENT_URL=http://127.0.0.1:9911/print
PRINT_AGENT_SECRET=
PRINT_AGENT_TIMEOUT=5
PRINT_AGENT_FAIL_SOFT=true
